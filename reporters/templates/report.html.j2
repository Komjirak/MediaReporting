<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ company_name }} 미디어 리포트 - {{ run_label }} ({{ run_time }})</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
         font-size: 14px; color: #222; background: #f5f5f5; }
  .container { max-width: 1100px; margin: 20px auto; background: #fff;
               border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.12); overflow: hidden; }

  /* ── 헤더 ── */
  .header { background: #1a1a2e; color: #fff; padding: 24px 32px; }
  .header h1 { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
  .header .meta { font-size: 12px; color: #aaa; }

  /* ── 감사 배너 ── */
  .audit-banner { padding: 12px 32px; font-size: 13px; }
  .audit-banner.error   { background: #fff0f0; border-left: 4px solid #e53e3e; color: #c53030; }
  .audit-banner.warning { background: #fffbeb; border-left: 4px solid #d69e2e; color: #975a16; }
  .audit-banner h3 { margin-bottom: 6px; font-size: 14px; }
  .audit-banner ul { padding-left: 18px; }

  /* ── 리스크 요약 ── */
  .risk-summary { display: flex; gap: 12px; padding: 20px 32px; background: #f9f9f9;
                  border-bottom: 1px solid #eee; flex-wrap: wrap; }
  .risk-card { flex: 1; min-width: 120px; padding: 14px 16px; border-radius: 6px;
               text-align: center; color: #fff; }
  .risk-card.critical { background: #e53e3e; }
  .risk-card.high     { background: #dd6b20; }
  .risk-card.medium   { background: #d69e2e; }
  .risk-card.low      { background: #38a169; }
  .risk-card .count  { font-size: 28px; font-weight: 700; }
  .risk-card .label  { font-size: 11px; opacity: .85; margin-top: 2px; }

  /* ── 테이블 ── */
  .section { padding: 24px 32px; }
  .section h2 { font-size: 16px; font-weight: 700; margin-bottom: 14px; color: #333;
                border-bottom: 2px solid #e8e8e8; padding-bottom: 8px; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead tr { background: #f0f0f0; }
  th, td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #eee;
           vertical-align: top; }
  th { font-weight: 600; color: #444; white-space: nowrap; }
  tr:hover { background: #fafafa; }

  /* ── 리스크 배지 ── */
  .badge { display: inline-block; padding: 2px 8px; border-radius: 20px;
           font-size: 11px; font-weight: 700; white-space: nowrap; }
  .badge.CRITICAL { background: #fed7d7; color: #c53030; }
  .badge.HIGH     { background: #feebc8; color: #9c4221; }
  .badge.MEDIUM   { background: #fefcbf; color: #7b6002; }
  .badge.LOW      { background: #c6f6d5; color: #276749; }

  /* ── 소스 배지 ── */
  .src-badge { display: inline-block; padding: 2px 8px; border-radius: 4px;
               font-size: 11px; background: #ebf8ff; color: #2b6cb0; }

  /* ── 기사 제목 링크 ── */
  .article-link { color: #2b6cb0; text-decoration: none; font-weight: 600; }
  .article-link:hover { text-decoration: underline; }
  .article-meta { font-size: 11px; color: #888; margin-top: 3px; }
  .summary-text { font-size: 12px; color: #555; margin-top: 4px; line-height: 1.5; }

  /* ── 커버리지 매트릭스 ── */
  .coverage { background: #f9f9f9; padding: 20px 32px; border-top: 1px solid #eee; }
  .coverage h3 { font-size: 14px; font-weight: 700; margin-bottom: 10px; color: #444; }
  .coverage pre { font-size: 12px; background: #fff; padding: 12px; border-radius: 4px;
                  border: 1px solid #ddd; overflow-x: auto; }

  /* ── 푸터 ── */
  .footer { background: #1a1a2e; color: #888; font-size: 11px;
            padding: 14px 32px; text-align: center; }

  @media print {
    .container { box-shadow: none; margin: 0; }
    body { background: #fff; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- 헤더 -->
  <div class="header">
    <h1>📰 {{ company_name }} 미디어 모니터링 리포트</h1>
    <div class="meta">
      {{ run_label }} &nbsp;|&nbsp; 생성: {{ run_time }} KST &nbsp;|&nbsp;
      수집 기간: 최근 {{ hours_back }}시간 &nbsp;|&nbsp; 총 {{ articles|length }}건
    </div>
  </div>

  <!-- 감사 배너 -->
  {% if audit_flags %}
  {% set error_flags = audit_flags | selectattr("severity", "equalto", "ERROR") | list %}
  {% set warn_flags  = audit_flags | selectattr("severity", "equalto", "WARNING") | list %}
  {% if error_flags %}
  <div class="audit-banner error">
    <h3>⛔ 감사 오류 - 즉시 확인 필요</h3>
    <ul>
      {% for f in error_flags %}<li>[{{ f.flag_type or f.type }}] {{ f.flag_detail or f.detail }}</li>{% endfor %}
    </ul>
  </div>
  {% endif %}
  {% if warn_flags %}
  <div class="audit-banner warning">
    <h3>⚠️ 감사 경고</h3>
    <ul>
      {% for f in warn_flags %}<li>[{{ f.flag_type or f.type }}] {{ f.flag_detail or f.detail }}</li>{% endfor %}
    </ul>
  </div>
  {% endif %}
  {% endif %}

  <!-- 리스크 요약 카드 -->
  <div class="risk-summary">
    <div class="risk-card critical">
      <div class="count">{{ articles | selectattr("risk_level","equalto","CRITICAL") | list | length }}</div>
      <div class="label">CRITICAL</div>
    </div>
    <div class="risk-card high">
      <div class="count">{{ articles | selectattr("risk_level","equalto","HIGH") | list | length }}</div>
      <div class="label">HIGH</div>
    </div>
    <div class="risk-card medium">
      <div class="count">{{ articles | selectattr("risk_level","equalto","MEDIUM") | list | length }}</div>
      <div class="label">MEDIUM</div>
    </div>
    <div class="risk-card low">
      <div class="count">{{ articles | selectattr("risk_level","equalto","LOW") | list | length }}</div>
      <div class="label">LOW</div>
    </div>
  </div>

  <!-- 기사 목록 -->
  <div class="section">
    <h2>기사 목록</h2>
    {% if articles %}
    <table>
      <thead>
        <tr>
          <th style="width:42%">제목</th>
          <th style="width:9%">소스</th>
          <th style="width:10%">발행시각</th>
          <th style="width:10%">카테고리</th>
          <th style="width:8%">리스크</th>
          <th style="width:21%">요약</th>
        </tr>
      </thead>
      <tbody>
        {% for art in articles %}
        <tr>
          <td>
            <a class="article-link" href="{{ art.url }}" target="_blank">{{ art.title }}</a>
            <div class="article-meta">키워드: {{ art.keyword }}</div>
          </td>
          <td><span class="src-badge">{{ art.source }}</span></td>
          <td style="white-space:nowrap; font-size:12px;">
            {{ art.published_at[:16] | replace("T"," ") }}
          </td>
          <td style="font-size:12px;">{{ art.category or "-" }}</td>
          <td><span class="badge {{ art.risk_level }}">{{ art.risk_level }}</span></td>
          <td>
            <div class="summary-text">{{ art.summary_ko or (art.description | default(''))[:120] or "-" }}</div>
            {% if art.risk_reason %}
            <div class="article-meta" style="color:#c53030;">⚠ {{ art.risk_reason }}</div>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p style="color:#999; text-align:center; padding:40px 0;">
      해당 기간 수집된 기사가 없습니다.
    </p>
    {% endif %}
  </div>

  <!-- 커버리지 매트릭스 -->
  <div class="coverage">
    <h3>📊 키워드 커버리지 매트릭스 (최근 24시간)</h3>
    <pre>{{ coverage_matrix }}</pre>
  </div>

  <!-- 푸터 -->
  <div class="footer">
    MediaReporting System &nbsp;|&nbsp;
    Powered by Claude AI &nbsp;|&nbsp;
    Generated at {{ run_time }} KST
  </div>

</div>
</body>
</html>
