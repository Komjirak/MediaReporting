# =============================================
# MediaReporting 환경설정 템플릿
# 이 파일을 .env로 복사하고 값을 채워주세요
# =============================================

# ---- 회사/모니터링 설정 ----
COMPANY_NAME=회사명
# 검색 키워드 (쉼표 구분)
KEYWORDS=회사명,영문사명,대표이름,주요제품
# 리스크 키워드 (쉼표 구분) - HIGH 이상으로 분류
RISK_KEYWORDS_HIGH=소송,벌금,리콜,수사,징계,사고,구속,기소
# CRITICAL 키워드
RISK_KEYWORDS_CRITICAL=기소,구속,파산,대규모사고,사망

# ---- Naver 검색 API ----
# https://developers.naver.com 에서 애플리케이션 등록
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ---- Gemini API (기사 요약용) ----
# https://aistudio.google.com/apikey 에서 무료 발급
# 무료: 분당 15건 / 하루 1,500건 | Flash 모델로 저렴하게 사용
GEMINI_API_KEY=your_gemini_api_key

# ---- 이메일 (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
# 수신자 (쉼표 구분)
EMAIL_RECIPIENTS=recipient1@company.com,recipient2@company.com

# ---- Slack Webhook ----
# https://api.slack.com/apps 에서 Incoming Webhook URL 발급
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ---- 모니터링 설정 ----
# 스케줄 외 실시간 모니터링 간격 (초, 기본 300=5분)
MONITOR_INTERVAL_SECONDS=300
# 감사(audit) 최소 기사 수 기준 (이 이하면 경고)
AUDIT_MIN_ARTICLES=3
